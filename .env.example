# ============================================================
# Copia este archivo como .env y completa los valores.
# NUNCA subas el .env real a GitHub.
# ============================================================

# Base de datos PostgreSQL (Neon u otro proveedor)
DATABASE_URL=postgresql://usuario:contrasena@host/nombre_db?sslmode=require

# Django — genera una clave con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=tu-clave-secreta-aqui

# True solo en desarrollo local, False en producción
DEBUG=True

# Hosts permitidos separados por coma
ALLOWED_HOSTS=localhost,127.0.0.1
