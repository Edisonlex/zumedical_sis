# ============================================================
# CONFIGURACIÓN DE ENTORNO - ZUMedical Sistema Prenatal
# ============================================================
# Copia este archivo como .env y llena los valores para desarrollo local
# En Railway, configura estas variables en el dashboard (Settings > Variables)

# --- Base de datos PostgreSQL (Neon o Railway) ---
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_db?sslmode=require

# --- Django ---
# Genera una nueva clave segura con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=tu-clave-segura-aqui

# --- Para PRODUCCIÓN ---
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,*
